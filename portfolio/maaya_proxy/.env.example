# Primary provider
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

# Optional fallback provider for the Maaya LLM gateway
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.5-flash

# Provider order. Maaya tries each configured provider before falling back locally.
MAAYA_LLM_PROVIDERS=groq,gemini

# Local development only. Do not set PORT manually on Render.
PORT=8008
